
-64bit

+incdir+${proj_root}
+incdir+${proj_root}/source
+incdir+${proj_root}/source/sv/rtl
+incdir+${proj_root}/source/sv/rtl/tb

+incdir+${proj_root}/source/sv/timer_tb
+incdir+${proj_root}/source/sv/timer_tb/tb
+incdir+${proj_root}/source/sv/timer_tb/include
+incdir+${proj_root}/source/sv/timer_tb/include/addons
+incdir+${proj_root}/source/sv/timer_tb/include/addons/ifx_dig_data_bus_uvc
+incdir+${proj_root}/source/sv/timer_tb/include/addons/ifx_dig_data_bus_uvc/ifx_dig_data_bus_uvc_pkg_and_if
+incdir+${proj_root}/source/sv/timer_tb/include/env
+incdir+${proj_root}/source/sv/timer_tb/include/env/registers
+incdir+${proj_root}/source/sv/timer_tb/include/tests
-sv
-gui
// RTL compilation files
${proj_root}/source/rtl/*.sv

// SV env compilation files
${proj_root}/source/sv/timer_tb/include/env/ifx_dig_defines.svh
${proj_root}/source/sv/timer_tb/include/addons/ifx_dig_data_bus_uvc/ifx_dig_data_bus_uvc_pkg_and_if/*.sv
${proj_root}/source/sv/timer_tb/include/env/registers/*.sv
${proj_root}/source/sv/timer_tb/include/env/*.sv
${proj_root}/source/sv/timer_tb/include/tests/*.sv
${proj_root}/source/sv/timer_tb/tb/*.sv

-access rwc
-linedebug
-clean
-uvm
-uvmlinedebug
-coverage all
-covoverwrite
-timescale 1ns/1ps
-errormax 2
-ALLOWREDEFINITION
-top ifx_dig_top

