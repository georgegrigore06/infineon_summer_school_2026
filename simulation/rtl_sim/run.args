
-64bit

+incdir+${proj_root}
+incdir+${proj_root}/source
+incdir+${proj_root}/source/sv/rtl
+incdir+${proj_root}/source/sv/rtl/tb
-sv
-gui
// RTL compilation files
${proj_root}/source/sv/rtl/*.sv
${proj_root}/source/sv/rtl/tb/*.sv
-access rwc
-linedebug
-uvm
-uvmlinedebug
-coverage all
-covoverwrite
-timescale 1ns/1ps
-errormax 2
-ALLOWREDEFINITION


