database -open waves -into waves.shm -default
probe -create -shm test_top.clk test_top.rst test_top.in test_top.dut.counter_core.counter_timer.rise_event test_top.dut.counter_core.counter_timer.fall_event test_top.dut.register_block.COUNTER_VALUE test_top.out_global test_top.dut.register_block.CAPTURE_VALUE test_top.dut.register_block.CTRL0 test_top.dut.register_block.PWM_MODE test_top.dut.register_block.CNT_MODE0
run
probe -create -shm test_top.dut.register_block.COMMAND
reset
run
exit
